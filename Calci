from art import CALC
print(CALC)
def add(n1, n2):
    return n1 + n2
def subtract(n1, n2):
    return n1 - n2
def multiply(n1, n2):
    return n1 * n2
def divide(n1, n2):
    return n1 / n2

operations = {
    "+": add,
    "-": subtract,
    "*": multiply,
    "/": divide,
}

repeat = True
skip = True

while repeat:
    if skip:
        num1 = float(input("What is the first number?: "))
    for symbol in operations:
        print(symbol)
    operation_symbol = input("Pick an operation: ")
    num2 = float(input("What is the next number?: "))
    result = operations[f"{operation_symbol}"](num1, num2)
    print(result)
    should_continue = input(f"Type 'y' to continue calculating with {result}, or type 'n' to start a new calculation:  ").lower()
    if should_continue == "y":
        num1 = result
        skip = False
    elif should_continue == "n":
        skip = True
        print("\n" * 999)
        print(CALC)
